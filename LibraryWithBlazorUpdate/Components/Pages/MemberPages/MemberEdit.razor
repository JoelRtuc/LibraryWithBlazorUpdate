@page "/members/edit/{id}"
@rendermode InteractiveServer

@using LibraryWithBlazorUpdate.Data
@using LibraryWithBlazorUpdate.Components.Models

@inject LibraryWithBlazorUpdateContext Context
@inject NavigationManager Navigation

<PageTitle>Edit Member</PageTitle>

<div class="container mt-4">
    <h1>Edit Member</h1>

    @if (member == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <EditForm Model="member" OnValidSubmit="HandleUpdateMember">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Member ID</label>
                <InputText class="form-control" @bind-Value="member.memberId" Disabled="true" />
            </div>

            <div class="mb-3">
                <label for="memberName" class="form-label">Name</label>
                <InputText id="memberName" @bind-Value="member.memberName" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" @bind-Value="member.email" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Member Since</label>
                <InputDate @bind-Value="member.memberSince" class="form-control" />
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <NavLink class="btn btn-secondary" href="/members">Cancel</NavLink>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public string id { get; set; }

    private Member member;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(id))
        {
            member = await Context.Members.FindAsync(id);
        }

        if (member == null)
        {
            message = "Member not found.";
        }
    }

    private async Task HandleUpdateMember()
    {
        try
        {
            Context.Members.Update(member);
            await Context.SaveChangesAsync();
            Navigation.NavigateTo("/members");
        }
        catch (Exception ex)
        {
            message = $"Error updating member: {ex.Message}";
        }
    }
}
