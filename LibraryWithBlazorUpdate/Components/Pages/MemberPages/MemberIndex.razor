@page "/members"
@rendermode InteractiveServer

@using LibraryWithBlazorUpdate.Data
@using LibraryWithBlazorUpdate.Components.Models
@using Microsoft.EntityFrameworkCore

@inject LibraryWithBlazorUpdateContext Context
@inject NavigationManager Navigation

<PageTitle>Members</PageTitle>

<div>
    <p>
        Search:
    </p>
    <InputText @bind-Value="searchTerm" />
    <p>
        @searchTerm
    </p>
</div>

<div class="container mt-4">
    <h1>Members</h1>
    <p>
        <NavLink class="btn btn-primary" href="/members/create">Register New Member</NavLink>
    </p>

    @if (members == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (members.Count == 0)
    {
        <p><em>No members found.</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Member Since</th>
                    <th>Loans Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in members)
                {
                    if (searchTerm == string.Empty || member.Matches(searchTerm))
                    {
                        <tr>
                            <td>@member.memberId</td>
                            <td>@member.memberName</td>
                            <td>@member.email</td>
                            <td>@member.memberSince.ToShortDateString()</td>
                            <td>@member.loans.Count</td>
                            <td>
                                <NavLink class="btn btn-sm btn-info" href="@($"/members/details/{member.memberId}")">Details</NavLink>
                                <NavLink class="btn btn-sm btn-warning" href="@($"/members/edit/{member.memberId}")">Edit</NavLink>
                                <NavLink class="btn btn-sm btn-danger" href="@($"/members/delete/{member.memberId}")">Delete</NavLink>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Member> members;
	private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        members = await Context.Members
            .Include(m => m.loans)
            .ToListAsync();
    }
}
