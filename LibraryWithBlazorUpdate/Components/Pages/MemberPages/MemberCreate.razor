@page "/members/create"
@rendermode InteractiveServer

@using LibraryWithBlazorUpdate.Data
@using LibraryWithBlazorUpdate.Components.Models

@inject LibraryWithBlazorUpdateContext Context
@inject NavigationManager Navigation

<PageTitle>Create Member</PageTitle>

<div class="container mt-4">
    <h1>Create New Member</h1>

    <div class="row">
        <div class="col-md-6">
            <EditForm Model="newMember" OnValidSubmit="HandleCreateMember">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="memberId" class="form-label">Member ID</label>
                    <InputText id="memberId" @bind-Value="newMember.memberId" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="memberName" class="form-label">Name</label>
                    <InputText id="memberName" @bind-Value="newMember.memberName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <InputText id="email" @bind-Value="newMember.email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="memberSince" class="form-label">Member Since</label>
                    <InputDate id="memberSince" @bind-Value="newMember.memberSince" class="form-control" />
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <NavLink class="btn btn-secondary" href="/members">Back to List</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private Member newMember = new();
    private string message = "";

    protected override void OnInitialized()
    {
        newMember.memberSince = DateTime.Now;
    }

    private async Task HandleCreateMember()
    {
        try
        {
            Context.Members.Add(newMember);
            await Context.SaveChangesAsync();
            Navigation.NavigateTo("/members");
        }
        catch (Exception ex)
        {
            message = $"Error creating member: {ex.Message}";
        }
    }
}
