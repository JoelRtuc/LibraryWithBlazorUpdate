@page "/library-items/delete/{id:int}"
@rendermode InteractiveServer

@using LibraryWithBlazorUpdate.Data
@using LibraryWithBlazorUpdate.Components.Models

@inject LibraryWithBlazorUpdateContext Context
@inject NavigationManager Navigation

<PageTitle>Delete Library Item</PageTitle>

<div class="container mt-4">
    <h1>Delete Library Item</h1>
    <h3>Are you sure you want to delete this item?</h3>

    @if (item == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card border-danger">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Title:</strong></div>
                            <div class="col-sm-8">@item.title</div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Author:</strong></div>
                            <div class="col-sm-8">@item.author</div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Published Year:</strong></div>
                            <div class="col-sm-8">@item.publishedYear</div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-4"><strong>Available:</strong></div>
                            <div class="col-sm-8">@(item.isAvailable ? "Yes" : "No")</div>
                        </div>

                        <div class="mt-4">
                            <button class="btn btn-danger" @onclick="HandleDeleteItem">Delete</button>
                            <NavLink class="btn btn-secondary" href="/library-items">Cancel</NavLink>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private LibraryItem item;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        item = await Context.LibraryItems.FindAsync(Id);
    }

    private async Task HandleDeleteItem()
    {
        try
        {
            if (item != null)
            {
                Context.LibraryItems.Remove(item);
                await Context.SaveChangesAsync();
                Navigation.NavigateTo("/library-items");
            }
        }
        catch (Exception ex)
        {
            message = $"Error deleting item: {ex.Message}";
        }
    }
}
