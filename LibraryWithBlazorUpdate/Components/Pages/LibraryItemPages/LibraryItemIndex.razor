@page "/library-items"
@rendermode InteractiveServer

@using LibraryWithBlazorUpdate.Data
@using LibraryWithBlazorUpdate.Components.Models
@using Microsoft.EntityFrameworkCore

@inject LibraryWithBlazorUpdateContext Context
@inject NavigationManager Navigation

<PageTitle>Library Items</PageTitle>

<div>
    <p>
        Search:
    </p>
    <InputText @bind-Value="searchTerm"/>
    <p>
        @searchTerm
    </p>
</div>

<div class="container mt-4">
    <h1>Library Items</h1>
    <p>
        <NavLink class="btn btn-primary" href="/library-items/create">Add New Item</NavLink>
    </p>

    @if (items == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (items.Count == 0)
    {
        <p><em>No library items found.</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Published Year</th>
                    <th>Available</th>
                    <th>Type</th>
                    <th>Loan History</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items.Where(p => p.Matches(searchTerm) || searchTerm == string.Empty).OrderBy(p => p.title))
                {
                    <tr>
                        <td>@item.title</td>
                        <td>@item.author</td>
                        <td>@item.publishedYear</td>
                        <td>@(item.isAvailable ? "Yes" : "No")</td>
                        <td>@GetItemType(item)</td>
                        <td>@item.loans.Count</td>
                        <td>
                            <NavLink class="btn btn-sm btn-info" href="@($"/library-items/details/{item.Id}")">Details</NavLink>
                            <NavLink class="btn btn-sm btn-warning" href="@($"/library-items/edit/{item.Id}")">Edit</NavLink>
                            <NavLink class="btn btn-sm btn-danger" href="@($"/library-items/delete/{item.Id}")">Delete</NavLink>
                            @if(item.isAvailable)
                            {
                                <NavLink class="btn btn-sm btn-success" href="@($"/loans/create?libraryItemId={item.Id}")">Loan</NavLink>
                            }
                            else
                            {
                                int index = 0;
                                foreach (Loan loan in item.loans)
                                {
                                    if (loan.LibraryItemId == item.Id)
                                    {
                                        index = loan.Id;
                                    }
                                }
                                <NavLink class="btn btn-sm btn-danger" href="@($"/loans/delete/{index}")">Return</NavLink>

                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<LibraryItem> items;
    string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        items = await Context.LibraryItems.ToListAsync();
    }

    private string GetItemType(LibraryItem item)
    {
        return item switch
        {
            Book => "Book",
            Movie => "Movie",
            Magazine => "Magazine",
            _ => "Unknown"
        };
    }
}
